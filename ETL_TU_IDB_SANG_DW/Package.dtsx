                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT * FROM (
    SELECT 
        (YEAR(Ngay_Dat) * 100) + DATEPART(week, Ngay_Dat) AS KhoaTG,
        YEAR(Ngay_Dat) AS Nam,
        MIN(MONTH(Ngay_Dat)) AS Thang,
        DATEPART(week, Ngay_Dat) AS Tuan
    FROM IDB_HeThongCu.dbo.Don_Dat_Hang
    GROUP BY 
        (YEAR(Ngay_Dat) * 100) + DATEPART(week, Ngay_Dat),
        YEAR(Ngay_Dat),
        DATEPART(week, Ngay_Dat)
) AS SourceData
-- ĐIỀU KIỆN CHẶN TRÙNG:
WHERE SourceData.KhoaTG NOT IN (SELECT KhoaTG FROM KhoDuLieu_BanHang.dbo.Dim_ThoiGian);</property>
