                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    Ma_MH, 
    Kich_co, 
    Trong_Luong, 
    Gia, 
    Mo_Ta
FROM IDB_HeThongCu.dbo.Mat_Hang AS S
WHERE NOT EXISTS (
    SELECT 1 FROM KhoDuLieu_BanHang.dbo.Dim_MatHang AS D
    WHERE D.MaMH = S.Ma_MH
);</property>
