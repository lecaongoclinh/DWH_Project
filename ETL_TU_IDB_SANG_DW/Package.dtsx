              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT * FROM (
    SELECT 
        Ma_CH, 
        Ma_MH, 
        -- Tạo Khóa thời gian dạng NămTuần (VD: 202414)
        (YEAR(Thoi_Gian_Luu_Tru) * 100) + DATEPART(week, Thoi_Gian_Luu_Tru) AS KhoaTG,
        -- Tính tổng số lượng tồn
        SUM(So_Luong) AS SoLuongTon
    FROM [IDB_HeThongCu].[dbo].[Mat_Hang_Luu_Tru]
    GROUP BY 
        Ma_CH, 
        Ma_MH, 
        (YEAR(Thoi_Gian_Luu_Tru) * 100) + DATEPART(week, Thoi_Gian_Luu_Tru)
) AS SourceData
-- CHẶN TRÙNG: Chỉ lấy bộ ba (Cửa hàng, Mặt hàng, Tuần) chưa có trong kho
WHERE NOT EXISTS (
    SELECT 1 FROM [KhoDuLieu_BanHang].[dbo].[Fact_TonKho] f
    WHERE f.MaCH = SourceData.Ma_CH 
      AND f.MaMH = SourceData.Ma_MH 
      AND f.KhoaTG = SourceData.KhoaTG
);</property>
                <property
