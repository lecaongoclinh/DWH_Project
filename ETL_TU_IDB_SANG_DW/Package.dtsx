                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT Ma_TP, Bang, Ten_TP, Dia_Chi_VP 
FROM IDB_HeThongCu.dbo.Van_Phong_Dai_Dien AS S
WHERE NOT EXISTS (
    SELECT 1 FROM KhoDuLieu_BanHang.dbo.Dim_DiaDiem AS D
    WHERE D.MaTP = S.Ma_TP
)</property>
