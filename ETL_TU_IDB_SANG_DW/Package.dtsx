                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    d.Ma_KH, 
    c.Ma_MH, 
    -- Ép kiểu Ngày đặt thành Khóa Tuần (Ví dụ: Năm 2023 Tuần 9 -&gt; 202309)
    (YEAR(d.Ngay_Dat) * 100) + DATEPART(week, d.Ngay_Dat) AS KhoaTG,
    SUM(c.So_Luong) AS soluonghangdat, 
    SUM(c.So_Luong * c.Gia_Tien) AS tongtien
FROM Don_Dat_Hang d
INNER JOIN Mat_Hang_Duoc_Dat c ON d.Ma_Don = c.Ma_Don
GROUP BY 
    d.Ma_KH, 
    c.Ma_MH, 
    (YEAR(d.Ngay_Dat) * 100) + DATEPART(week, d.Ngay_Dat)</property>
